#Heatmap Code:
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

nutritionDataset = pd.read_csv(r"C:\Users\kitty\Downloads\foodandnut\comprehensive_foods_usda.csv")

nutrient_features = [
    "calories", "protein_g", "fat_g", "carbs_g", "fiber_g",
    "sugar_g", "sodium_mg", "iron_mg", "calcium_mg", "vitamin_c_mg"
]

corr_matrix = nutritionDataset[nutrient_features].corr()

#Heatmap: 
plt.figure(figsize = (10, 8))
sns.set(style = "whitegrid")
sns.heatmap(corr_matrix, cmap = "coolwarm", linewidths = 0.5, cbar_kws = {"shrink": 0.8})
plt.title("Heatmap of Nutritional Features")
plt.tight_layout()
plt.show()
